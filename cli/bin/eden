    });
  }
  if (!draft.source) {
    warnings.push({
      path: "source",
      message: `Missing source; defaulted to "${source}"`
    });
  }
  const items = [];
  const personaByCode = /* @__PURE__ */ new Map();
  const firstPersonaCode = draft.personas[0]?.code;
