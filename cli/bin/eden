// src/client.ts
var import_child_process = require("child_process");
var SERVICE = "API";
var cachedApiUrl;
function getApiUrl() {
  if (cachedApiUrl) return cachedApiUrl;
  const envUrl = process.env[`EVE_APP_API_URL_${SERVICE}`];
  if (envUrl) {
    const resolvedUrl = envUrl.replace(/\/$/, "");
    cachedApiUrl = resolvedUrl;
    return resolvedUrl;
  }
  try {
    const out = (0, import_child_process.execSync)("eve api show api --json 2>/dev/null", { encoding: "utf8", timeout: 5e3 });
    const info = JSON.parse(out);
    if (info.base_url) {
      const resolvedUrl = info.base_url.replace(/\/$/, "");
      cachedApiUrl = resolvedUrl;
      return resolvedUrl;
    }
  } catch {
  }
  console.error(`Error: EVE_APP_API_URL_${SERVICE} not set and auto-discovery failed.`);
  console.error("Are you running inside an Eve job with with_apis: [api]?");
  process.exit(1);
}
async function api(method, path, body) {
  const url = getApiUrl();
  const token = process.env.EVE_JOB_TOKEN;
  const res = await fetch(`${url}${path}`, {
    method,
    headers: {
      "Content-Type": "application/json",
      ...token ? { Authorization: `Bearer ${token}` } : {}
    },
    body: body ? JSON.stringify(body) : void 0
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    const msg = formatMessage(err.message) || res.statusText;
    console.error(`${method} ${path} \u2192 ${res.status}: ${msg}`);
    printIssues("error", err.errors);
    printIssues("warning", err.warnings);
    process.exit(1);
  }
  if (res.status === 204) {
    return void 0;
  }
  const text = await res.text();
  if (!text.trim()) {
    return void 0;
  }
  let json2;
  try {
    json2 = JSON.parse(text);
  } catch {
    return text;
  }
  if (json2 && typeof json2 === "object" && "data" in json2 && Array.isArray(json2.data)) {
    return json2.data;
  }
  return json2;
}
function formatMessage(value) {
  if (typeof value === "string" && value.trim()) {
    return value;
  }
  if (Array.isArray(value)) {
    const parts = value.filter((item) => typeof item === "string" && item.trim().length > 0).map((item) => item.trim());
    if (parts.length > 0) {
      return parts.join("; ");
    }
  }
  return void 0;
}
function printIssues(kind, value) {
  if (!Array.isArray(value)) {
    return;
  }
  for (const issue of value) {
    if (!issue || typeof issue !== "object") {
      continue;
    }
    const { path, message } = issue;
    if (typeof message !== "string" || !message.trim()) {
      continue;
    }
    const formattedPath = typeof path === "string" && path.trim() ? `${path.trim()} - ` : "";
    console.error(`  ${kind}: ${formattedPath}${message.trim()}`);
  }
}

// src/output.ts
function json(data) {
  console.log(JSON.stringify(data, null, 2));
}
function table(rows, columns) {
  if (rows.length === 0) {
    console.log("(no results)");
    return;
  }
  const first = rows[0];
  const cols = columns ?? Object.keys(first);
  const widths = cols.map(
    (c) => Math.max(
      c.length,
      ...rows.map((row) => String(row[c] ?? "").length)
    )
  );
  console.log(cols.map((c, i) => c.padEnd(widths[i])).join("  "));
  console.log(cols.map((_, i) => "\u2500".repeat(widths[i])).join("  "));
  for (const row of rows) {
    const data = row;
    console.log(cols.map((c, i) => String(data[c] ?? "").padEnd(widths[i])).join("  "));
  }
}

// src/utils.ts
var import_promises = require("fs/promises");
var UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
function isUuid(value) {
  return UUID_RE.test(value);
}
function parseInteger(value, label = "number") {
  const parsed = Number.parseInt(value, 10);
  if (!Number.isNaN(parsed)) {
    return parsed;
  }
  console.error(`Invalid ${label}: ${value}`);
  process.exit(1);
}
async function readJsonFile(filePath) {
  try {
    const content = await (0, import_promises.readFile)(filePath, "utf8");
    return JSON.parse(content);
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    console.error(`Failed to read JSON from ${filePath}: ${message}`);
    process.exit(1);
  }
}
function parseJsonOption(value, label) {
  try {
    return JSON.parse(value);
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    console.error(`Invalid ${label} JSON: ${message}`);
    process.exit(1);
  }
}
function ensureBody(body, message = "Provide at least one field to update") {
  if (Object.keys(body).length > 0) {
    return;
  }
  console.error(message);
  process.exit(1);
}
function resolveIdFromItems(explicit, items, opts) {
  if (isUuid(explicit)) {
    return explicit;
  }
  const target = opts.caseInsensitive ? explicit.toLowerCase() : explicit;
  const matches = items.filter((item) => {
    const record = item;
    return opts.fields.some((field) => {
      const raw = record[field];
      if (typeof raw !== "string") return false;
      return opts.caseInsensitive ? raw.toLowerCase() === target : raw === target;
    });
  });
  if (matches.length === 1) {
    return matches[0].id;
  }
  const formatter = opts.formatter ?? ((item) => item.id);
  console.error(`${opts.label} not found: "${explicit}". Available ${opts.label.toLowerCase()}s:`);
  for (const item of items) {
    console.error(`  ${formatter(item)}`);
  }
  process.exit(1);
}

// src/commands/projects.ts
function registerProjects(program3) {
  const projects = program3.command("projects").alias("project").description("Manage Eden projects");
  projects.command("list").description("List all projects").option("--json", "JSON output").action(async (opts) => {
    const data = await api("GET", "/projects");
    if (opts.json) return json(data);
    table(data, ["id", "name", "slug"]);
  });
  projects.command("create").description("Create a project").requiredOption("--name <name>", "Project name").requiredOption("--slug <slug>", "Project slug").option("--json", "JSON output").action(async (opts) => {
    const data = await api("POST", "/projects", {
      name: opts.name,
      slug: opts.slug
    });
    if (opts.json) return json(data);
    console.log(`Created project: ${data.id} (${data.slug})`);
  });
  projects.command("show").alias("get").description("Show project details").argument("<id>", "Project ID").option("--json", "JSON output").action(async (id, opts) => {
    const data = await api("GET", `/projects/${id}`);
    if (opts.json) return json(data);
    console.log(`Project: ${data.name}`);
    console.log(`ID: ${data.id}`);
    console.log(`Slug: ${data.slug}`);
    console.log(`Created: ${data.created_at}`);
  });
  projects.command("delete").description("Delete a project").argument("<id>", "Project ID").action(async (id) => {
    await api("DELETE", `/projects/${id}`);
    console.log(`Deleted project: ${id}`);
  });
  projects.command("update").description("Update a project").argument("<id>", "Project ID or slug").option("--name <name>", "Project name").option("--json", "JSON output").action(async (id, opts) => {
    const projectId = await autoDetectProject(id);
    const body = {
      ...opts.name && { name: opts.name }
    };
    ensureBody(body);
    const data = await api("PATCH", `/projects/${projectId}`, body);
    if (opts.json) return json(data);
    console.log(`Updated project: ${data.id} (${data.slug})`);
  });
}
async function autoDetectProject(explicit) {
  if (explicit && UUID_RE.test(explicit)) return explicit;
  const projects = await api("GET", "/projects");
  if (explicit) {
    const match = projects.find((p) => p.slug === explicit || p.name === explicit);
    if (match) return match.id;
    console.error(`Project not found: "${explicit}". Available projects:`);
    for (const p of projects) console.error(`  ${p.slug}  ${p.id}  ${p.name}`);
    process.exit(1);
  }
  if (projects.length === 1) return projects[0].id;
  if (projects.length === 0) {
    console.error("No projects found.");
    process.exit(1);
  }
  console.error("Multiple projects found. Specify --project <id-or-slug>:");
  for (const p of projects) console.error(`  ${p.slug}  ${p.id}  ${p.name}`);
  process.exit(1);
}

// src/commands/map.ts
function registerMap(program3) {
  const map = program3.command("map").description("Show the project story map").argument("[project]", "Project ID or slug").option("--project <id>", "Project ID (auto-detected if only one)").option("--persona <code>", "Filter by persona code").option("--release <id>", "Filter by release").option("--json", "JSON output").action(async (projectArg, opts) => {
    await showMap(projectArg ?? opts.project, opts);
  });
  map.command("get").alias("show").description("Show the project story map").argument("[project]", "Project ID or slug").option("--project <id>", "Project ID (auto-detected if only one)").option("--persona <code>", "Filter by persona code").option("--release <id>", "Filter by release").option("--json", "JSON output").action(async (projectArg, opts) => {
    const parentOpts = map.opts();
    await showMap(projectArg ?? opts.project ?? parentOpts.project, {
      json: opts.json ?? parentOpts.json,
      persona: opts.persona ?? parentOpts.persona,
      release: opts.release ?? parentOpts.release
    });
  });
}
async function showMap(project, opts) {
  const pid = await autoDetectProject(project);
  const params = new URLSearchParams();
  if (opts.persona) params.set("persona", opts.persona);
  if (opts.release) params.set("release", opts.release);
  const qs = params.toString() ? `?${params}` : "";
  const map = await api("GET", `/projects/${pid}/map${qs}`);
  if (opts.json) return json(map);
  printMap(map);
}
function printMap(map) {
  console.log(`Project: ${map.project.name} (${map.project.id})`);
  if (map.personas?.length) {
    console.log(`Personas: ${map.personas.map((p) => `${p.code} (${p.name})`).join(", ")}`);
  }
  console.log("");
  for (const activity of map.activities ?? []) {
    console.log(`[${activity.display_id}] ${activity.name}`);
    for (const step of activity.steps ?? []) {
      console.log(`  [${step.display_id}] ${step.name}`);
      for (const task of step.tasks ?? []) {
        const persona = task.persona_code ? ` @${task.persona_code}` : "";
        const status = task.status ? ` (${task.status})` : "";
        console.log(`    [${task.display_id}] ${task.title}${persona}${status}`);
      }
    }
  }
}

